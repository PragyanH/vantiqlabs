'use client';import {useEffect,useState} from 'react';import {useRouter} from 'next/navigation';import DashSidebar from '@/components/dashboard/DashSidebar';import DashMain from '@/components/dashboard/DashMain';import {getCurrentUser} from '@/lib/auth';import {supabase} from '@/lib/supabase';import {type AlumniProfileWithCollege} from '@/lib/types'
export default function DashboardPage(){const r=useRouter(),[name,setName]=useState(''),[mentors,setMentors]=useState<AlumniProfileWithCollege[]>([]),[error,setError]=useState('');useEffect(()=>{const load=async()=>{const user=await getCurrentUser();if(!user){r.replace('/auth/signin');return}const [{data:student,error:studentError},{data:profiles,error:profilesError}]=await Promise.all([supabase.from('students').select('full_name').eq('auth_user_id',user.id).maybeSingle(),supabase.from('alumni_profiles').select('*, colleges(name, slug)').eq('is_published',true).limit(3)]);if(studentError||profilesError){console.error('Unable to load dashboard:',studentError?.message||profilesError?.message);setError('We couldn’t load all dashboard details right now.')}setName(student?.full_name||user.email?.split('@')[0]||'there');setMentors((profiles||[]) as AlumniProfileWithCollege[])};load()},[r]);if(!name&&!error)return <main className="dashboard"><div className="empty"><b>Loading your dashboard…</b></div></main>;return <main className="dashboard"><DashSidebar/><DashMain name={name||'there'} mentors={mentors} error={error}/></main>}
