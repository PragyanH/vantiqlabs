'use client'
import Link from 'next/link';import {useRouter} from 'next/navigation';import {useState} from 'react';import {supabase} from '@/lib/supabase'
export default function AuthCard({mode}:{mode:'signin'|'signup'}){const r=useRouter(),[theme,setTheme]=useState<'light'|'dark'>('dark'),[fullName,setFullName]=useState(''),[college,setCollege]=useState('BMSIT&M'),[email,setEmail]=useState(''),[password,setPassword]=useState(''),[error,setError]=useState(''),[loading,setLoading]=useState(false),signup=mode==='signup';const handleGoogleSignIn=async()=>{setError('');const {error}=await supabase.auth.signInWithOAuth({provider:'google',options:{redirectTo:`${window.location.origin}/dashboard`}});if(error){console.error('Google sign-in error:',error);setError(error.message)}};const submit=async(e:React.FormEvent)=>{e.preventDefault();setError('');setLoading(true);try{if(signup){const {data,error:signUpError}=await supabase.auth.signUp({email,password});if(signUpError)throw signUpError;if(!data.user)throw new Error('Please check your email to confirm your account, then sign in.');const {data:collegeRow,error:collegeError}=await supabase.from('colleges').select('id').eq('name',college).maybeSingle();if(collegeError||!collegeRow)throw collegeError||new Error('Selected college could not be found.');const {error:studentError}=await supabase.from('students').insert({auth_user_id:data.user.id,full_name:fullName,college_id:collegeRow.id});if(studentError)throw studentError}else{const {error:signInError}=await supabase.auth.signInWithPassword({email,password});if(signInError)throw signInError}r.push('/dashboard')}catch(err){const message=err instanceof Error?err.message:'Authentication failed. Please try again.';console.error('Authentication error:',err);setError(message)}finally{setLoading(false)}};return <main className={'auth-page '+theme}><button className="auth-back" onClick={()=>r.push('/')}>←</button><div className="auth-brand">✦ VantiqLabs</div><button className="theme-toggle" onClick={()=>setTheme(theme==='dark'?'light':'dark')}>{theme==='dark'?'☀':'☾'}<span>{theme==='dark'?'Light':'Dark'} mode</span></button><section className="auth-card"><div className="auth-kicker">{signup?'START YOUR VANTIQ JOURNEY':'WELCOME BACK'}</div><h1>{signup?'Create your account':'Sign in to VantiqLabs'}</h1><p>{signup?'Already have an account?':'New to VantiqLabs?'} <Link href={signup?'/auth/signin':'/auth/signup'}>{signup?'Sign in':'Create an account'}</Link></p><form onSubmit={submit}>{signup&&<><label>Full name<input value={fullName} onChange={e=>setFullName(e.target.value)} required placeholder="Enter your full name"/></label><label>College<select value={college} onChange={e=>setCollege(e.target.value)}><option>BMSIT&amp;M</option><option>MSRIT</option></select></label></>}<label>College email<input value={email} onChange={e=>setEmail(e.target.value)} required type="email" placeholder="you@college.edu"/></label><label>Password<input value={password} onChange={e=>setPassword(e.target.value)} required minLength={6} type="password" placeholder="Enter your password"/></label>{error&&<p className="notice">{error}</p>}<button className="auth-submit" disabled={loading} type="submit">{loading?'Please wait…':signup?'Create your account →':'Sign in to your account →'}</button></form><div className="auth-divider"><span>OR CONTINUE WITH</span></div><button className="social-auth" onClick={handleGoogleSignIn}><b className="google-g">G</b>Continue with Google</button></section></main>}
</file>

