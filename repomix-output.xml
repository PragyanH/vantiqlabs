'use client';import {useMemo,useState} from 'react';import {type AlumniProfileWithCollege} from '@/lib/types';import MentorCard from '@/components/ui/MentorCard'
export default function BrowseContent({college,mentors}:{college:string;mentors:AlumniProfileWithCollege[]}){const [query,setQuery]=useState('');const filtered=useMemo(()=>mentors.filter(m=>(college==='All colleges'||m.colleges?.name===college||m.colleges?.slug===college)&&`${m.name} ${m.role} ${m.company} ${(m.expertise||[]).join(' ')}`.toLowerCase().includes(query.toLowerCase())),[college,query,mentors]);return <section className="browse-content"><div className="browse-heading"><div><p className="section-kicker">VERIFIED PEOPLE, PRACTICAL ADVICE</p><h1>Explore mentors</h1></div><span>{filtered.length} mentors</span></div><div className="search-wide"><span className="icon">⌕</span><input value={query} onChange={e=>setQuery(e.target.value)} placeholder="Search by name, role, company, or skill"/><button onClick={()=>setQuery('')}>Clear</button></div><div className="chip-row"><button className="chip active">All expertise</button><button className="chip">Engineering</button><button className="chip">Product</button></div>{mentors.length===0?<div className="empty"><b>We&apos;re onboarding our first mentors — check back soon.</b></div>:filtered.length?<div className="mentor-grid all">{filtered.map(m=><MentorCard key={m.id} mentor={m} href={'/profile/'+m.id}/>)}</div>:<div className="empty"><b>No mentors match that search.</b></div>}</section>}
</file>

