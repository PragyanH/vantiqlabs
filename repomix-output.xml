@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
:root{font-family:'Plus Jakarta Sans',sans-serif;color:#15152c;background:#fff;line-height:1.5}*{box-sizing:border-box}body{margin:0}button,input{font:inherit}button{cursor:pointer;border:0;background:none;color:inherit}h1,h2,h3,p{margin:0}h1{font-size:clamp(2.45rem,5vw,5rem);line-height:1.05;letter-spacing:-.065em}h2{font-size:clamp(1.8rem,3vw,2.7rem);letter-spacing:-.055em;line-height:1.15}h3{letter-spacing:-.03em}em{font-style:normal;color:#4f46e5}.topbar{height:72px;display:flex;align-items:center;justify-content:space-between;padding:0 max(5vw,28px);border-bottom:1px solid #f1f1f5;background:#ffffffeb;backdrop-filter:blur(14px);position:sticky;top:0;z-index:10}.brand{font-weight:800;font-size:1.05rem}.brand b{color:#4f46e5;margin-right:7px}.topbar nav{display:flex;align-items:center;gap:26px;font-size:.78rem;font-weight:600;color:#636377}.topbar nav button:hover,.text-btn:hover{color:#4f46e5}.login{margin-left:12px}.btn{background:#4f46e5;color:white;border-radius:9px;padding:13px 18px;font-weight:700;font-size:.82rem;box-shadow:0 5px 14px #4f46e52b}.btn:hover{background:#3730a3}.small-btn{padding:10px 14px}.menu{display:none;font-size:1.35rem}.hero{padding:76px max(7vw,28px) 70px;min-height:570px;background:radial-gradient(circle at 78% 48%,#eeedff 0,transparent 25%),linear-gradient(120deg,#fff 35%,#f8f8ff)}.hero-grid{max-width:1200px;margin:auto;display:grid;grid-template-columns:1.08fr .92fr;gap:30px;align-items:center}.eyebrow,.section-kicker{font-size:.62rem;letter-spacing:.1em;font-weight:800;color:#63637a;margin-bottom:18px}.eyebrow{max-width:1200px;margin:0 auto 16px;color:#4f46e5}.hero p{color:#6e6e80;max-width:500px;font-size:.92rem;margin:19px 0 25px}.finder,.search-wide{display:flex;align-items:center;background:white;border:1px solid #e5e5ef;border-radius:10px;padding:5px 6px 5px 14px;max-width:560px;box-shadow:0 7px 22px #2525640c}.icon{font-size:1.1rem;color:#818195}.finder input,.search-wide input{border:0;outline:0;width:100%;padding:10px;font-