export default function BookingFlow({mentor}:{mentor:AlumniProfileWithCollege}){const r=useRouter(),[step,setStep]=useState(1),[date,setDate]=useState('Thu, 24 Jul'),[time,setTime]=useState('6:00 PM');if(step===4)return <main className="booking"><div className="confirmation"><div className="success">✓</div><h1>You’re all set.</h1><p>Your session with {mentor.name} is confirmed for {date} at {time}.</p><button className="btn" onClick={()=>r.push('/dashboard')}>Go to my dashboard →</button></div></main>;return <main className="booking"><button className="back" onClick={()=>r.back()}>← Back</button><div className="progress">{['Choose a time','Review','Payment'].map((x,i)=><div className={step===i+1?'active':''} key={x}><b>{i+1}</b><span>{x}</span></div>)}</div><div className="booking-grid"><section><h1>{step===1?'Choose a time that works.':step===2?'Review your session.':'Secure payment.'}</h1>{step===1&&<><div className="date-row">{['Tue, 22 Jul','Wed, 23 Jul','Thu, 24 Jul','Fri, 25 Jul'].map(x=><button key={x} className={date===x?'selected':''} onClick={()=>setDate(x)}>{x}</button>)}</div><div className="slots">{['10:00 AM','2:00 PM','4:30 PM','6:00 PM'].map(x=><button key={x} className={time===x?'selected':''} onClick={()=>setTime(x)}>{x}</button>)}</div></>}{step===2&&<div className="review"><b>30-minute mentorship session with {mentor.name} · ₹{mentor.rate_call_30min}</b><p>{date} · {time}</p></div>}{step===3&&<div className="pay-form"><label>Cardholder name<input placeholder="Your full name"/></label><p className="fine">Prototype checkout — no payment will be processed.</p></div>}<button className="btn next" onClick={()=>setStep(step===3?4:step+1)}>Continue →</button></section></div></main>}
