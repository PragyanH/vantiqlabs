<file path="components/home/shared.tsx">
'use client'
import {useState} from 'react';import {useRouter} from 'next/navigation';import ComingSoon from '@/components/ui/ComingSoon';import {comingColleges,liveColleges} from '@/lib/types'
export function HeroSection(){const r=useRouter();return <section className="editorial-hero"><div className="hero-copy"><div className="pill">MENTOR-LED CAREER ACCELERATION</div><h1>Your college network.<br/>Your career <em>playbook.</em></h1><p>VantiqLabs connects ambitious engineering students with verified alumni who have already built the careers they want.</p><div className="hero-actions"><button className="outline-cta" onClick={()=>r.push('/browse')}>View mentor network</button><button className="dark-cta" onClick={()=>r.push('/browse')}>Start exploring →</button></div></div><div className="product-frame"><div className="browser-bar"><i/><i/><i/><span>vantiqlabs.in</span></div><div className="mini-product"><div className="mini-nav"><b>✦ VantiqLabs</b><span>Mentors</span><span>Roadmaps</span></div><p>Find someone who knows the way.</p><h3>Meet mentors who built<br/>the careers you want.</h3></div></div></section>}
export function CampusMarquee(){const r=useRouter(),[soon,setSoon]=useState<string|null>(null),names=[...liveColleges,...comingColleges.map(x=>x[0])];return <><section className="campus-marquee"><p>Growing across Bengaluru&apos;s engineering colleges</p><div className="marquee-window"><div className="marquee-track">{[0,1].map(g=><div className="marquee-group" key={g}>{names.map(n=><button key={g+n} onClick={()=>liveColleges.includes(n as never)?r.push('/browse?college='+encodeURIComponent(n)):setSoon(n)} className={liveColleges.includes(n as never)?'campus-logo live':'campus-logo'}><i>{n.slice(0,3)}</i><b>{n}</b><span>{liveColleges.includes(n as never)?'MENTORS LIVE':'COMING SOON'}</span></button>)}</div>)}</div></div></section>{soon&&<ComingSoon name={soon} close={()=>setSoon(null)}/>}</>}
export function CompanyMarquee(){const c=['Airbus','Google','ABB','Siemens','TCS','Amazon','Microsoft','Walmart','Accenture','IBM','Cisco'];return <section className="company-marquee"><p>Companies our mentors have experience with</p><div className="marquee-window"><div className="marquee-track reverse">{[0,1].map(g=><div className="marquee-group" key={g}>{c.map(n=><div className="company-logo" key={g+n}><i>{n.slice(0,2)}</i><b>{n}</b></div>)}</div>)}</div></div></section>}
export function Comparison(){return <section className="comparison"><div className="editorial-heading"><span>THE DIFFERENCE</span><h2>How career planning feels<br/>before and after VantiqLabs.</h2><p>Less noise. More evidence. A person who has actually done it.</p></div><img src="/assets/career-clarity-comparison.png" alt="Career clarity comparison"/><div className="compare-grid"><div><small>WITHOUT VANTIQ</small><h3>Scattered advice</h3><p>Conflicting videos and endless guessing.</p></div><div><small>WITH VANTIQ</small><h3>A path built for you</h3><p>Relevant mentors and clear next steps.</p></div></div></section>}
export function FeatureShowcase(){return <><section className="feature-intro"><span>MEET VANTIQ</span><h2>Everything between ambition<br/>and an offer—made clearer.</h2></section><section className="feature-showcase">{[['01 · DISCOVER','Mentor match engine','Find college-relevant people whose direction matches your goal.'],['02 · LEARN','Career playbooks','Turn a real journey into practical, visible milestones.'],['03 · CONNECT','Focused 1:1 sessions','Book time when context and honest feedback matter.']].map(([n,h,p],i)=><article className="sticky-feature" key={h}><div className="feature-visual"><b>{i+1}</b><h3>{h}</h3></div><div className="feature-copy"><span>{n}</span><h2>{h}</h2><p>{p}</p></div></article>)}</section></>}
export function MentorEconomy(){const benefits=[['Earn on your terms','Set your own rates and availability, then get paid for every call you choose to take.'],['Build meaningful influence','Be the reason a junior from your own college lands the role they have been working toward.'],['Stay in control','Choose the requests that feel right for you, and pause your availability whenever life gets busy.']];return <section className="mentor-economy"><div className="editorial-heading"><span>FOR ALUMNI</span><h2>Turn experience into impact.</h2></div><div className="economy-grid"><div className="benefit-stack">{benefits.map(([title,copy])=><article key={title}><b>✦</b><h3>{title}</h3><p>{copy}</p></article>)}</div><blockquote><div><h3>What students want, is what we deliver</h3><p>We know students do not need another generic AI roadmap or advice from someone whose path feels impossible to relate to. They need honest, realistic guidance from someone who has been in their exact shoes and understands the questions, trade-offs, and uncertainty that come with their situation.</p></div><div className="economy-testimonial">“The best guidance comes from someone only a few years ahead.”</div><footer><div className="avatar small" style={{background:'#0f766e'}}>NR</div><div><b>Nisha Rao</b><span>MSRIT alumna · Product at Microsoft</span></div></footer></blockquote></div></section>}
export function Outcomes(){return <section className="outcomes"><div className="editorial-heading"><span>WHAT CHANGES</span><h2>Clarity compounds quickly.</h2></div><div className="timeline">{[['Today','Stop guessing'],['30 days','Build the right proof'],['90 days','Move with confidence']].map(([a,b])=><div key={a}><b>{a}</b><article><h3>{b}</h3><p>Take the next move with relevant context.</p></article></div>)}</div></section>}
export function Scale(){return <section className="scale"><div className="editorial-heading"><span>BUILT TO GROW</span><h2>Small network. Serious depth.</h2></div><div className="scale-grid">{[['2','COLLEGES LIVE'],['6','FOUNDING MENTORS'],['8','CAMPUSES NEXT'],['1:1','HUMAN CONTEXT']].map(([a,b])=><article key={b}><b>{a}</b><span>{b}</span><p>Built around trusted communities.</p></article>)}</div></section>}
export function Voices(){const reviews=[['I had been rejected from two internships and was quietly assuming I was not good enough. My mentor had faced almost the same pattern a year earlier and showed me what to change in my applications. The next round felt far less random because I finally understood what recruiters were seeing.','Student · BMSIT&M'],['The interview questions my mentor shared were not generic lists from the internet. Two of the themes came up almost exactly in my final interview. More importantly, I knew how to explain my thinking instead of just memorising answers.','Student · MSRIT'],['I came in with a very polished but completely unrealistic prep schedule. My mentor’s honest reflection helped me cut it down to the work that actually mattered. I stopped chasing every YouTube checklist and started finishing things.','Student · BMSIT&M'],['It sounds small, but having someone I could ask “dumb” questions changed everything. They explained things without making me feel behind, because they remembered being in the same college a few years ago. That kind of context is hard to find on LinkedIn.','Student · MSRIT'],['Most career content I found was either too broad or made every journey look perfect. Here, my mentor spoke openly about rejections, delayed offers, and the decisions they would make differently. It felt useful because it was honest.','Student · BMSIT&M'],['I was trying to switch from core engineering to product and did not know which projects would count. My mentor helped me shape one project into a story that made sense to a product interviewer. I left each call with a clear next step.','Student · MSRIT'],['Giving back has been more meaningful than I expected. Students from my own college ask questions I remember having, and I can answer them without pretending there is one perfect path. The conversations are candid and genuinely energising.','Alumnus · BMSIT&M'],['I enjoy that students arrive with context instead of treating every call like a generic coffee chat. It lets us talk about their real work, confidence, and choices. Seeing a student turn that clarity into an offer is incredibly rewarding.','Alumna · MSRIT'],['My mentor looked at my resume for ten minutes and identified the exact gap I had been missing for months. We then planned how to prove that skill through one focused project. It was more valuable than another round of scattered online advice.','Student · BMSIT&M'],['The best part was learning what not to prepare. My mentor explained which topics mattered for the roles I wanted and which ones were just creating anxiety. I finally had permission to focus.','Student · MSRIT'],['I expected a formal session, but it felt like a senior being straightforward with me. We talked through my weak interview answer, practised it, and made it sound like my own voice. That made the next interview much less intimidating.','Student · BMSIT&M'],['Mentoring through VantiqLabs is structured enough to respect my time but personal enough to matter. I can choose requests that match my experience and see the impact quickly. It is a thoughtful way to stay connected to campus.','Alumna · MSRIT']];return <section className="voices"><div className="editorial-heading"><span>STUDENT VOICES</span><h2>We operate on trust and loyalty, here are our user reviews.</h2></div><div className="marquee-window voice-marquee"><div className="marquee-track">{[0,1].map(g=><div className="marquee-group" key={g}>{reviews.map(([quote,by],i)=><blockquote key={`${g}-${i}`}><p>“{quote}”</p><footer>{by}</footer></blockquote>)}</div>)}</div></div></section>}
export function FAQ(){const [open,setOpen]=useState(0),items=[['Who is VantiqLabs for?','Engineering students and alumni who want practical guidance.'],['How are mentors verified?','College and professional experience are reviewed.'],['Which colleges are live?','BMSIT&M and MSRIT are live first.'],['How do pricing and unlocks work?','Mentors set transparent prices for calls and deeper roadmap unlocks. You will always see the cost before choosing to book or unlock anything.'],['How are mentor calls booked and scheduled?','Choose a mentor, select an available time, and confirm the session through the booking flow. You will receive the relevant session details once your booking is confirmed.'],['Are payments refundable?','Refund eligibility depends on the booking status and the situation. If a mentor cannot attend or there is a platform issue, our support team will help resolve it fairly.'],['How do alumni get paid?','Alumni choose their rates and availability, then receive payment for completed sessions through the platform’s payment process.'],['What if there is no mentor for my target company yet?','Tell us what you are aiming for and keep exploring adjacent roles. We are continually onboarding alumni, and the network will expand with the needs students share.'],['How can I become a verified mentor?','Apply with your college and professional background. We review the details to make sure students can rely on the experience and guidance being offered.']];return <section className="faq-section"><div className="editorial-heading"><span>QUESTIONS, ANSWERED</span><h2>Frequently asked questions.</h2></div><div className="faq-list">{items.map(([q,a],i)=><article className={open===i?'open':''} key={q}><button onClick={()=>setOpen(open===i?-1:i)}><b>{q}</b><i>↓</i></button><div><p>{a}</p></div></article>)}</div></section>}
export function MentorOrbit(){const r=useRouter(),p=['mentor-airbus.png','mentor-google.png','mentor-product.png','mentor-data.png','mentor-electrical.png','mentor-design.png','mentor-security.png','mentor-manager.png'];return <section className="mentor-orbit"><div className="orbit-stage"><div className="orbit-arc"/>{p.map((x,i)=><img key={x} src={'/assets/'+x} alt="VantiqLabs mentor" style={{animationDelay:`-${i*4}s`}}/>)}</div><div className="orbit-center"><span>PEOPLE, NOT NOISE</span><h2>Career clarity is<br/>closer than it feels.</h2><p>Meet alumni who understand your starting point.</p><button className="dark-cta" onClick={()=>r.push('/browse')}>Meet your mentors →</button></div></section>}
</file>

